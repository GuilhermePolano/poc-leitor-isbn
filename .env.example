# Banco
# Em ambiente Docker, manter DB_HOST=db (nome do serviço no docker-compose.yml).
# Em ambiente sem Docker (PHP/MySQL local), trocar para DB_HOST=localhost.
DB_HOST=db
DB_PORT=3306
DB_NAME=isbn_app
DB_USER=isbn_user
DB_PASS=changeme

# APIs
GOOGLE_BOOKS_API_KEY=
APP_TIMEOUT_API_SEGUNDOS=5
APP_CACHE_DIAS=30

# Defaults para pré-preenchimento dos campos HYB na tela
HYB_UNIDADE_DEFAULT=UN
HYB_CATEGORIA_DEFAULT=Livros
HYB_NCM_DEFAULT=4901.99.00
HYB_PATRIMONIO_DEFAULT=N
HYB_TIPO_DEFAULT=Móvel
HYB_ESTOQUE_MINIMO_DEFAULT=0
HYB_ESTOQUE_INICIAL_QTD_DEFAULT=1

# App
APP_TIMEZONE=America/Sao_Paulo
APP_DEBUG=false
EXPORT_DIR=storage/exports
